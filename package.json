{
  "name": "proteus",
  "version": "1.0.0",
  "type": "module",
  "description": "A CLI for switching providers, models, and config profiles for AI developer tools.",
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "list": "tsx src/cli/index.ts --list",
    "validate": "tsx src/cli/index.ts --validate",
    "dev:go": "cd go && go run ./cmd/proteus",
    "list:go": "cd go && go run ./cmd/proteus --list",
    "validate:go": "cd go && go run ./cmd/proteus --validate",
    "build:bun": "mkdir -p dist && bun build --compile --target=bun src/cli/index.ts --outfile=dist/proteus"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
